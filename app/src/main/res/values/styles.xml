<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.PI2DAM.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_l</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_l</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_l</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_l</item>
        <item name="boxStrokeColor">@color/brand_orange</item>
    </style>

    <style name="Widget.PI2DAM.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/radius_l</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="backgroundTint">@color/brand_orange</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.PI2DAM.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_l</item>
        <item name="strokeColor">@color/brand_orange</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/brand_orange</item>
    </style>

    <style name="Widget.PI2DAM.Button.Primary.Compact" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/radius_m</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:minWidth">44dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="backgroundTint">@color/brand_orange</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.PI2DAM.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/brand_orange</item>
    </style>

    <style name="TextAppearance.PI2DAM.ScreenTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.PI2DAM.ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.PI2DAM.Link" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/link_blue</item>
    </style>

    <style name="TextAppearance.PI2DAM.MenuTitle" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.PI2DAM.MenuSubtitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.PI2DAM.MenuSection" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.PI2DAM.MenuItemTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.PI2DAM.MenuItemSubtitle" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.PI2DAM.MenuCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/radius_xl</item>
        <item name="cardElevation">2dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/menu_card_stroke</item>
        <item name="cardBackgroundColor">@color/menu_card</item>
    </style>

    <style name="Widget.PI2DAM.MenuChip" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">@dimen/radius_l</item>
        <item name="chipBackgroundColor">@color/menu_chip_bg</item>
        <item name="chipStrokeColor">@color/menu_card_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.PI2DAM.TextInputLayout.MenuSearch" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_l</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_l</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_l</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_l</item>
        <item name="boxStrokeColor">@color/menu_card_stroke</item>
        <item name="boxBackgroundColor">@color/menu_card</item>
    </style>
</resources>
